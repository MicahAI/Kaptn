#!/usr/bin/env python3
"""Kaptn PreToolUse hook — daemonless plugin entry point.

Claude Code pipes the hook event JSON to stdin; we print the decision
JSON to stdout. Always exits 0: any failure (old Python, bad input,
internal error) fails open to Claude Code's normal permission flow.

Stdlib only — no venv, no pip. Requires Python 3.10+; older interpreters
exit silently (this file itself parses on 3.8+ by design).
"""
import json
import os
import sys

if sys.version_info < (3, 10):
    sys.exit(0)  # fail open — the bridge modules need modern Python

PLUGIN_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, PLUGIN_ROOT)


def main():
    try:
        event = json.loads(sys.stdin.read() or "{}")
    except ValueError:
        return 0

    try:
        from bridge.standalone.runner import handle_event
        result = handle_event(event)
    except Exception:
        return 0  # fail open

    if result:
        print(json.dumps(result))
    return 0


if __name__ == "__main__":
    sys.exit(main())
